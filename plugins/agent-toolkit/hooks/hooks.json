{
  "description": "PreToolUse: Write/Edit/MultiEditのガードレール（文字化け・PS1改行・ロックファイル/シークレット編集・plan-modeスキル先行呼び出し催促）、Bashのgit commit警告・git log --decorate自動付与・codex exec念押し。PostToolUse: Bashのテスト実行・git状態確認・codex resume回数・Skillのplan-mode呼び出しをセッション状態に記録。Stop: ユーザー修正が多いセッション終了時にCLAUDE.md更新を提案。agent-toolkitプラグインの一部。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script ${CLAUDE_PLUGIN_ROOT}/scripts/pretooluse.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script ${CLAUDE_PLUGIN_ROOT}/scripts/posttooluse.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script ${CLAUDE_PLUGIN_ROOT}/scripts/stop_advisor.py"
          }
        ]
      }
    ]
  }
}
