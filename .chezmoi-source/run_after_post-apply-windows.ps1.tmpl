Set-StrictMode -Version Latest
$ErrorActionPreference = 'Stop'

# dotfiles 後処理エントリポイント (Windows)。
# chezmoi apply 完了後に毎回実行する (run_after_* のため無条件実行)。
# 全ステップは冪等で、変更なしなら数秒で完了する。
#
# NOTE: 対応するLinux版 → run_after_post-apply.sh.tmpl
#
# 1. pytools を editable install する (pyproject.toml ハッシュと期待シム実在の両方をキャッシュキーとする)
# 2. dotfiles-post-apply.exe を実行する
#    (Claude 設定 / SSH config / 旧配布物の削除 / npmrc を順に更新)

$cacheDir = Join-Path $env:LOCALAPPDATA 'dotfiles'
$hashFile = Join-Path $cacheDir 'pytools.hash'
$currentHash = '{{ include (joinPath .chezmoi.workingTree "pyproject.toml") | sha256sum }}'
$cachedHash = ''
if (Test-Path $hashFile) {
    $cachedHash = (Get-Content $hashFile -Encoding UTF8 -Raw)
}

# キャッシュ判定は「入力ハッシュ一致」と「期待シム実在」の両方を条件とする。
# pyproject.toml のハッシュのみで判定すると、過去の uv tool install 部分失敗で
# シムが欠落したまま再インストールが永久にスキップされる事象が発生するため、
# post-apply 処理継続に必須のシムの実在もキャッシュキーへ組み込む。
$expectedShimDir = Join-Path $env:USERPROFILE '.local\bin'
$expectedShims = @('dotfiles-post-apply.exe')
function Test-ExpectedShims {
    foreach ($name in $expectedShims) {
        if (-not (Test-Path (Join-Path $expectedShimDir $name))) { return $false }
    }
    return $true
}
$needsReinstall = ($currentHash -ne $cachedHash) -or (-not (Test-ExpectedShims))

$viewerBin = Join-Path $env:USERPROFILE '.local\bin\claude-plans-viewer.exe'
# 再インストール時に claude-plans-viewer.exe や venv 内ファイルがロックされたまま
# tool venv 再構築が部分失敗する事象が確認されているため、viewer が起動中なら
# 先に停止させ、再インストール完了後に再度バックグラウンド起動する。
$viewerWasRunning = $false
if ($needsReinstall) {
    $viewerProcs = Get-Process -Name claude-plans-viewer -ErrorAction SilentlyContinue
    if ($viewerProcs) {
        $viewerWasRunning = $true
        Write-Host '  [pytools] claude-plans-viewer を一時停止'
        Stop-Process -InputObject $viewerProcs -Force
    }
}

# dotfiles-media-remote は pythonw.exe -m pytools.media_remote serve として起動する。
# プロセス名は pythonw のため Stop-Process -Name で識別できない。
# serve 起動時に %LOCALAPPDATA%\dotfiles\media-remote\pid へ記録された PID を読み取り、
# 当該プロセスが pythonw.exe かつコマンドラインに pytools.media_remote を含むことを
# CIM で確認したうえで停止する。
$mediaRemotePythonw = Join-Path $env:USERPROFILE '.local\share\uv\tools\pytools\Scripts\pythonw.exe'
$mediaRemotePidFile = Join-Path $env:LOCALAPPDATA 'dotfiles\media-remote\pid'
$mediaRemoteWasRunning = $false
if ($needsReinstall -and (Test-Path $mediaRemotePidFile)) {
    try {
        $mediaRemotePid = [int]((Get-Content $mediaRemotePidFile -Encoding UTF8 -Raw).Trim())
        $proc = Get-CimInstance Win32_Process -Filter "ProcessId=$mediaRemotePid" -ErrorAction SilentlyContinue
        if ($proc -and $proc.Name -eq 'pythonw.exe' -and $proc.CommandLine -like '*pytools.media_remote*') {
            $mediaRemoteWasRunning = $true
            Write-Host '  [pytools] dotfiles-media-remote を一時停止'
            Stop-Process -Id $mediaRemotePid -Force -ErrorAction SilentlyContinue
        }
    } catch {
        Write-Host "  [pytools] dotfiles-media-remote 停止処理をスキップ: $_"
    }
}

# post-apply 配下の出力は列 2 にインデントを揃える (詳細は pytools/post_apply.py 参照)。
if ($needsReinstall) {
    if ($currentHash -ne $cachedHash) {
        Write-Host '  [pytools] pyproject.toml に変更あり → 再インストール'
    } else {
        Write-Host '  [pytools] 期待シムが欠落 → 再インストール'
    }
    try {
        # $ErrorActionPreference = 'Stop' はネイティブ exe の非ゼロ終了を例外化しないため、
        # uv コマンド直後で $LASTEXITCODE を明示判定して throw する。
        # ハッシュ書き込みは uv tool install ・uv tool update-shell ・期待シム実在再確認のすべてが成功した場合のみ実行する。
        & uv tool install --editable "{{ .chezmoi.workingTree }}"
        if ($LASTEXITCODE -ne 0) { throw "uv tool install が失敗しました (exit=$LASTEXITCODE)" }
        & uv tool update-shell
        if ($LASTEXITCODE -ne 0) { throw "uv tool update-shell が失敗しました (exit=$LASTEXITCODE)" }
        if (-not (Test-ExpectedShims)) {
            throw '期待シムが生成されていません'
        }
        if (-not (Test-Path $cacheDir)) {
            New-Item -ItemType Directory -Path $cacheDir -Force | Out-Null
        }
        Set-Content -Path $hashFile -Value $currentHash -Encoding UTF8 -NoNewline
    } catch {
        Write-Host "  [pytools] インストールに失敗しました (後続処理は継続): $_"
    }
} else {
    Write-Host '  [pytools] 変更なし (ハッシュキャッシュヒット)'
}

# share/user.env をユーザー環境変数に設定する
$userEnvFile = Join-Path '{{ .chezmoi.workingTree }}' 'share\user.env'
if (Test-Path $userEnvFile) {
    Get-Content $userEnvFile -Encoding UTF8 | ForEach-Object {
        $line = $_.Trim()
        if ($line -eq '' -or $line.StartsWith('#')) { return }
        $idx = $line.IndexOf('=')
        if ($idx -lt 1) { return }
        $name = $line.Substring(0, $idx)
        $value = $line.Substring($idx + 1)
        # シングルクォートまたは二重クォートで囲まれた値を除去する
        if (($value.StartsWith("'") -and $value.EndsWith("'")) -or
            ($value.StartsWith('"') -and $value.EndsWith('"'))) {
            $value = $value.Substring(1, $value.Length - 2)
        }
        [System.Environment]::SetEnvironmentVariable($name, $value, 'User')
        Write-Host "  [user.env] $name を設定"
    }
}

# uv tool update-shell は現プロセスの PATH を更新しないため、フルパスで呼び出す
$postApplyBin = Join-Path $env:USERPROFILE '.local\bin\dotfiles-post-apply.exe'
if (Test-Path $postApplyBin) {
    # dotfiles-post-apply は chezmoi から独立した CLI のため、workingTree を環境変数で渡す
    $env:CHEZMOI_WORKING_TREE = '{{ .chezmoi.workingTree }}'
    & $postApplyBin
} else {
    Write-Host "  [pytools] $postApplyBin が見つからないため後処理スキップ"
}

# 再インストール前に停止した viewer を再起動する。
# post-apply 側に Windows 用のレストアステップは存在しないため、
# 本節が「停止済み → 明示的に再開」を単独で担う。
if ($viewerWasRunning -and (Test-Path $viewerBin)) {
    Write-Host '  [pytools] claude-plans-viewer を再起動'
    Start-Process -FilePath $viewerBin -WindowStyle Hidden
}

# 再インストール前に停止した media-remote を再起動する（stheno のみ）。
# 自動起動は post-apply 側のショートカット配置に委ねるが、再インストール中の停止からの
# 復帰だけは本節で担当する。
if ($mediaRemoteWasRunning -and $env:COMPUTERNAME -eq 'stheno' -and (Test-Path $mediaRemotePythonw)) {
    Write-Host '  [pytools] dotfiles-media-remote を再起動'
    Start-Process -FilePath $mediaRemotePythonw -WindowStyle Hidden -ArgumentList @('-m', 'pytools.media_remote', 'serve')
}
