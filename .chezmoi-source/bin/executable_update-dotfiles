#!/bin/bash -eu
# dotfiles を最新化する。
# NOTE: 対応するWindows版 → bin/executable_update-dotfiles.cmd
#
# chezmoi の実行順序:
#   1. update — git pull + apply (テンプレート再処理なし)
#   2. init   — テンプレートを再展開 (run_after_* は走らない)
#   3. apply  — 再展開後の source state を destination へ反映
#               (ここで run_after_post-apply が最終的に走り、後処理が完結)

echo "=== [1/3] chezmoi update ==="
chezmoi update --verbose --source ~/dotfiles

echo "=== [2/3] chezmoi init (テンプレート再展開) ==="
chezmoi init --source ~/dotfiles

echo "=== [3/3] chezmoi apply (post-apply 実行) ==="
chezmoi apply --verbose
