#!/bin/bash -eu
# dotfiles を最新化する。
# NOTE: 対応するWindows版 → bin/executable_update-dotfiles.cmd
#
# git pull → init → status (apply 予定のみ表示) → silent apply の 4 段で実行する。
# step 3 で「これから更新されるファイル」を一覧表示してから step 4 で apply を実行する構成のため、
# `chezmoi update` (= 内部で git pull + apply 一括) ではなく `chezmoi git pull` を使っている。

echo "=== [1/4] git pull ==="
chezmoi git --source ~/dotfiles -- pull --ff-only

echo "=== [2/4] chezmoi init (テンプレート再展開) ==="
chezmoi init --source ~/dotfiles

echo "=== [3/4] chezmoi status (apply 予定のファイル) ==="
# `chezmoi status` は 2 列構成。
#   1 列目 = 前回 chezmoi が書いた状態 vs 現在の destination 実ファイル
#   2 列目 = 現在の実ファイル vs target state (= これから apply で起きる変更)
# 今回知りたいのは「これから更新されるファイル」だけなので、2 列目が空白以外の行のみ抽出する。
# スクリプト (R) は毎回出やすくノイズになるため -x scripts で除外。
chezmoi status -x scripts | awk 'substr($0,2,1) != " "'

echo "=== [4/4] chezmoi apply (post-apply 実行) ==="
chezmoi apply
