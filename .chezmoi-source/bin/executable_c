#!/bin/bash -eu
# NOTE: 対応するWindows版 → bin/executable_c.cmd
echo -e "\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"

# clear
reset

# カレントディレクトリが git 作業ツリーなら git status を自動実行する。
# `.git` はディレクトリだけでなく worktree の場合はファイルになるので `-e` で判定する。
if [ -e .git ]; then
    git status
fi
