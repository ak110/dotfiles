# 対話環境用

# エイリアス
alias rm='rm -i'
alias mv='mv -i'
alias cp='cp -i'
function cd() {
    builtin cd "$@" && (
        ll
        if [ -e .git ]; then
            git status
        fi
    )
}
alias ..='cd ..'
function r() {
    reset
    # exec $SHELLはシェルを置き換えるため、残存ジョブ（停止中を含む）は失われる
    if [ -n "$(jobs -p)" ]; then
        echo "バックグラウンドジョブが残っているためシェルの再起動は行いません。" >&2
        jobs
        return 1
    fi
    exec "$SHELL"
}

# プロンプトのカスタマイズ
function _show_status() {
    # 終了コード表示
    local status=("${PIPESTATUS[@]}")
    local color="" # 白
    local s
    for s in "${status[@]}"; do
        if [ "${s}" -gt 100 ]; then
            color="\\033[1;31m" # 赤
            break
        elif [ "${s}" -gt 0 ]; then
            color="\\033[1;33m" # 黄
        fi
    done
    if [ -n "${color}" ]; then
        echo -en "${color}"
        echo "Exit code: ${status[*]}"
        echo -en "\\033[0;39m"
    fi
    # ウィンドウタイトルをホスト名にする(念のため毎回)
    echo -en "\\e]2;$(hostname)\\a"
}
PROMPT_COMMAND=${PROMPT_COMMAND//history -a;/}
PROMPT_COMMAND=${PROMPT_COMMAND//_show_status;/}
PROMPT_COMMAND="history -a;_show_status;${PROMPT_COMMAND}"

# pyenv
# 手動で有効化
function enable-pyenv() {
    if [ ! -d "$HOME/.pyenv" ]; then
        curl -sL https://pyenv.run | bash
    fi
    export PATH="$HOME/.pyenv/bin:$PATH"
    eval "$(pyenv init -)"
    eval "$(pyenv virtualenv-init -)"
    pyenv --version
    pyenv versions
}
# 既に存在したら自動で有効化する
# ただし、VIRTUAL_ENVがすでに有効ならスキップ
if [ -d "$HOME/.pyenv" ] && [ -z "$VIRTUAL_ENV" ]; then
    enable-pyenv
fi

# VSCode
if [ -e "$(which code)" ]; then
    # EDITOR は vim を使用するため、VISUAL のみ設定する
    export VISUAL="code --wait"
fi

# Claude Code
# 終了時に画面をクリアするラッパー関数。
# エイリアスではなく関数にしているのは、claude 本体の終了コードを保持しつつ
# 終了後に clear を実行する必要があるため。
# claude の所在は環境によって異なる:
#   - ~/.claude/local/claude: Claude Code 公式インストーラー (migrate-installer)
#     が生成する固定パス。PATH には通っていないので絶対パスで呼ぶ
#   - PATH 上の claude: npm global など別経路で入れた場合 (~/.local/bin/claude 等)
# 両方に対応するため、ガードでは OR で判定し、本体では公式版があればそれを優先する。
if [ -x ~/.claude/local/claude ] || command -v claude >/dev/null 2>&1; then
    claude() {
        # フラグのみの呼び出し（例: --model=sonnet）も対話セッションとみなして clear する。
        # -で始まらない引数またはヘルプ・非対話フラグがあれば非対話とみなす。
        # --model=sonnet 形式（=付き）は対話判定される。--model sonnet（空白区切り）は
        # sonnet が非フラグと誤判定されるため =付き形式での使用を前提とする。
        local is_interactive=1
        for arg in "$@"; do
            case "$arg" in
                --help|-h|--version|-v|--print|-p) is_interactive=0; break ;;
                -*) ;;
                *) is_interactive=0; break ;;
            esac
        done
        if [ -x ~/.claude/local/claude ]; then
            ~/.claude/local/claude "$@"
        else
            # 組み込み command で関数自身を bypass して PATH 上の本物を呼ぶ
            command claude "$@"
        fi
        local rc=$?
        # stdout/stderr が TTY のときだけ clear する。
        # パイプやリダイレクト経由で呼ばれた場合に端末制御シーケンスが
        # 出力へ混入するのを防ぐため。
        if [ "$is_interactive" -eq 1 ] && [ -t 1 ] && [ -t 2 ]; then
            ~/bin/c
        fi
        return $rc
    }
    # 計画ファイルの確認用コマンド
    plans() {
        mise use --global fzf glow
        find ~/.claude/plans -type f -name '*.md' -printf '%T@\t%TY-%Tm-%Td %TH:%TM\t%f\t%p\n' |
            sort \
                --numeric-sort \
                --reverse \
                --field-separator=$'\t' \
                --key=1,1 |
            fzf \
                --delimiter=$'\t' \
                --with-nth=2,3 \
                --nth=2,3 \
                --preview='glow --width=127 -- {4}' \
                --preview-window='bottom,70%,border-top' \
                --bind='enter:execute(${EDITOR:-nvim} -- {4})'
        # --width="${FZF_PREVIEW_COLUMNS:-100}" もありだが固定にしちゃう
    }
fi
# ccusageなど
alias ccusage="pnpx ccusage"
alias claude-code-viewer="pnpx @kimuson/claude-code-viewer@latest"

# nvm の bash 補完 (対話シェル専用)。
# nvm 本体は非対話セクションで source 済みのため NVM_DIR は既に export されている。
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# uv / pyfltr の bash 補完
if command -v uv &>/dev/null; then
    eval "$(uv generate-shell-completion bash)"
fi
if command -v pyfltr &>/dev/null; then
    # 古いpyfltrは generate-shell-completion サブコマンドを持たず、引数をlint対象とみなして実行してしまうため、
    # --helpの出力にサブコマンド名が含まれるかでバージョン非依存に判定する。
    if pyfltr --help 2>&1 | grep -q generate-shell-completion; then
        eval "$(pyfltr generate-shell-completion bash)"
    fi
fi

# ~/.localbashrc
if [ -e ~/.localbashrc ]; then
    source ~/.localbashrc
fi

