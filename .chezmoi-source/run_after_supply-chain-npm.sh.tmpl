#!/bin/bash
# サプライチェーン攻撃対策: npm/pnpmの公開後24時間(1440分)未満のパッケージを除外
npmrc="$HOME/.npmrc"
if [ -f "$npmrc" ] && grep -q '^minimum-release-age' "$npmrc"; then
    sed -i 's/^minimum-release-age=.*/minimum-release-age=1440/' "$npmrc"
elif [ -f "$npmrc" ]; then
    echo 'minimum-release-age=1440' >> "$npmrc"
else
    echo 'minimum-release-age=1440' > "$npmrc"
fi
