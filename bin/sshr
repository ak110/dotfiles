#!/usr/bin/env bash
# NOTE: 対応するWindows版 → bin/sshr.cmd
# ssh自動再接続ラッパー。
# - 引数はssh本体へ完全透過する
# - exit 0で終了 → ループ脱出
# - SIGINT (130) / SIGTERM (143) → 当該コードで終了
# - その他のexit code → 端末状態を初期化してからメッセージを表示し再実行
set -u

while :; do
    ssh "$@"
    code=$?
    case "$code" in
        0 | 130 | 143)
            exit "$code"
            ;;
    esac
    # tmux等が残したマウスモード・代替画面・SGR・カーソル状態を初期化する
    printf '\033[?1000l\033[?1002l\033[?1003l\033[?1004l\033[?1006l\033[?1015l\033[?2004l\033[?1049l\033[0m\033[?25h' >&2
    echo "[sshr] 切断されました (exit=${code})。再接続します... (Ctrl+C で終了)" >&2
done
