{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --script ${CLAUDE_PLUGIN_ROOT}/scripts/pretooluse.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash|Skill|Read|EnterPlanMode|Agent|Task|mcp__codex__codex",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --script ${CLAUDE_PLUGIN_ROOT}/scripts/posttooluse.py"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --script ${CLAUDE_PLUGIN_ROOT}/scripts/posttooluse.py"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --script ${CLAUDE_PLUGIN_ROOT}/scripts/posttooluse.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --script ${CLAUDE_PLUGIN_ROOT}/scripts/stop_advisor.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --script ${CLAUDE_PLUGIN_ROOT}/scripts/subagent_stop_advisor.py"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --script ${CLAUDE_PLUGIN_ROOT}/scripts/stopfailure_notifier.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --script ${CLAUDE_PLUGIN_ROOT}/scripts/permissionrequest.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --script ${CLAUDE_PLUGIN_ROOT}/scripts/user_prompt_submit.py"
          }
        ]
      }
    ]
  }
}
