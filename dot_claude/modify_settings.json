{{- /* chezmoi:modify-template */ -}}
{{- /* 既存のsettings.jsonを読み込み（未作成なら空オブジェクト） */ -}}
{{- $existing := "{}" -}}
{{- if ne .chezmoi.stdin "" -}}
{{-   $existing = .chezmoi.stdin -}}
{{- end -}}
{{- $data := fromJson $existing -}}

{{- /* 言語設定 */ -}}
{{- $_ := set $data "language" "japanese" -}}

{{- /* 管理対象のpermissions */ -}}
{{- $managedAllow := list "Bash" "Edit" "Glob" "Grep" "MultiEdit" "NotebookEdit" "Read" "Task" "TodoWrite" "WebFetch" "WebSearch" "Write" "mcp__serena" "mcp__plugin_serena_serena" -}}
{{- $managedDeny := list "Read(*.key)" "Read(*.crt)" "Read(./.env)" -}}

{{- /* 既存のpermissionsを取得 */ -}}
{{- $existingPerms := dict "allow" (list) "deny" (list) -}}
{{- if hasKey $data "permissions" -}}
{{-   $existingPerms = get $data "permissions" -}}
{{- end -}}
{{- $existingAllow := list -}}
{{- if hasKey $existingPerms "allow" -}}
{{-   $existingAllow = get $existingPerms "allow" -}}
{{- end -}}
{{- $existingDeny := list -}}
{{- if hasKey $existingPerms "deny" -}}
{{-   $existingDeny = get $existingPerms "deny" -}}
{{- end -}}

{{- /* unionマージ（管理リスト + ローカル追加分） */ -}}
{{- $mergedAllow := concat $existingAllow $managedAllow | uniq -}}
{{- $mergedDeny := concat $existingDeny $managedDeny | uniq -}}

{{- /* permissionsを更新して出力 */ -}}
{{- $_ := set $data "permissions" (dict "allow" $mergedAllow "deny" $mergedDeny) -}}
{{- toPrettyJson $data -}}
