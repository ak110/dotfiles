#!/bin/bash
# pyproject.toml hash: {{ include "pyproject.toml" | sha256sum }}
# claude_settings hash: {{ include "share/claude_settings_managed.json" | sha256sum }}
# claude_config hash: {{ include "share/claude_config_managed.json" | sha256sum }}
# NOTE: 対応するWindows版 → run_onchange_after_pytools-windows.ps1.tmpl
# chezmoi apply を止めないよう、失敗時は警告のみ
uv tool install --force --editable ~/dotfiles || echo "WARNING: pytools install failed"
# Claude Code settings.json を管理対象設定とマージ
command -v update-claude-settings && update-claude-settings || true
