#!/bin/bash
# .cmdファイルがUTF-8でエンコードされているか検証する。
# 非ASCIIバイトを含むファイルには chcp 65001 の記述も要求する。
set -eu

dir="${1:-.}"
errors=0

while IFS= read -r -d '' file; do
    if ! uv run --frozen python -c "
import sys

with open(sys.argv[1], 'rb') as f:
    data = f.read()

# UTF-8デコード検証
try:
    text = data.decode('utf-8')
except UnicodeDecodeError as e:
    print(f'{sys.argv[1]}: {e}')
    sys.exit(1)

# 非ASCIIバイトを含む場合、chcp 65001 の記述を要求する
if any(b > 127 for b in data) and 'chcp 65001' not in text.lower():
    print(f'{sys.argv[1]}: 非ASCIIバイトを含むUTF-8ファイルに chcp 65001 がありません')
    sys.exit(1)
" "$file"; then
        errors=$((errors + 1))
    fi
done < <(find "$dir" -name '*.cmd' -print0)

if [ "$errors" -gt 0 ]; then
    echo "ERROR: ${errors} file(s) with encoding issues"
    exit 1
fi
echo "OK: all .cmd files are valid UTF-8"
