{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": false,
  "autoMode": {
    "allow": [
      "Session-Owned Amend: `git commit --amend` を実行する対象が、同一セッション内でエージェント自身が作成したコミット（pre-session HEADではないコミット）であることを transcript から確認できる場合、レビュー指摘修正後の統合を含むあらゆるフローで無条件に許容する。本許可は対象コミットがエージェント作成であることを transcript で確認できる場合に限定し、pre-session HEAD・ユーザー作成コミットへのamendは対象外。",
      "Exit-Session Termination: `agent-toolkit:exit-session`スキル経由の`kill -TERM $PPID`は、呼び出し元スキルから明示的に呼ばれた場合、またはユーザーがSkill名を明示指定した場合の正当な自律終了操作であり許可する。本許可は`agent-toolkit:exit-session`スキルの起動条件を満たした状態でのシグナル送出に限定する。"
    ]
  },
  "effortLevel": "medium",
  "enabledPlugins": {
    "pr-review-toolkit@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": false,
    "superpowers@claude-plugins-official": false
  },
  "env": {
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_SCROLL_SPEED": "3"
  },
  "language": "japanese",
  "permissions": {
    "allow": [
      "Bash",
      "Bash(git push *)",
      "Edit",
      "NotebookEdit",
      "PowerShell",
      "Read",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Write",
      "mcp__codex",
      "mcp__plugin_context7_context7",
      "mcp__plugin_serena_serena",
      "mcp__serena"
    ],
    "defaultMode": "plan",
    "deny": [
      "Read(*.key)",
      "Read(*.crt)",
      "Read(./.env)"
    ]
  },
  "showClearContextOnPlanAccept": false,
  "showThinkingSummaries": false,
  "viewMode": "verbose"
}
