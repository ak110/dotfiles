{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'uv run --script ~/dotfiles/scripts/claude_hook_check_mojibake.py; code=$?; [ $code -eq 2 ] && exit 2 || exit 0'"
          },
          {
            "type": "command",
            "command": "sh -c 'uv run --script ~/dotfiles/scripts/claude_hook_check_ps1_eol.py; code=$?; [ $code -eq 2 ] && exit 2 || exit 0'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'uv run --script ~/dotfiles/scripts/claude_hook_call_formatter.py || exit 0'"
          }
        ]
      }
    ]
  }
}
