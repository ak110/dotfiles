{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "requiredMinimumVersion": "2.1.205",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'uv run --no-project --script ~/dotfiles/scripts/claude_hook_pretooluse.py; code=$?; [ $code -eq 2 ] && exit 2 || exit 0'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'uv run --no-project --script ~/dotfiles/scripts/claude_hook_posttooluse.py; exit 0'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'uv run --no-project --script ~/dotfiles/scripts/claude_hook_stop.py; exit 0'"
          },
          {
            "type": "command",
            "command": "sh -c 'uv run --no-project --script ~/dotfiles/scripts/claude_hook_autonomous_exit.py; exit 0'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh -c 'uv run --no-project --script ~/dotfiles/scripts/claude_status_line.py'",
    "padding": 0
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "sh -c 'uv run --no-project --script ~/dotfiles/scripts/claude_subagent_status_line.py'"
  }
}
