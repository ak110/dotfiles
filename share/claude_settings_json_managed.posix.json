{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'uv run --script ~/dotfiles/scripts/claude_hook_pretooluse.py; code=$?; [ $code -eq 2 ] && exit 2 || exit 0'"
          }
        ]
      }
    ]
  }
}
