root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

[*.{toml,yaml,json,jsonc,md,html,jinja2,js,ts,css,svg,xml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{cmd,cmd.tmpl,bat,bat.tmpl,ps1,ps1.tmpl,psm1,psd1}]
end_of_line = crlf

[*.{cmd,cmd.tmpl,bat,bat.tmpl}]
charset = unset

[*.{bat,bas,cls,dcm,frm,vbs}]
charset = unset
end_of_line = crlf

[Makefile]
indent_style = tab
